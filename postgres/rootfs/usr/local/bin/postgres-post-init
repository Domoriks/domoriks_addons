#!/command/with-contenv bashio
# shellcheck shell=bash

set -euo pipefail

sql_escape_literal() {
    printf '%s' "$1" | sed "s/'/''/g"
}

for _ in $(seq 1 60); do
    if gosu postgres "${POSTGRES_BIN_DIR}/pg_isready" -q -h /var/run/postgresql -p 5432; then
        break
    fi
    sleep 1
done

if ! gosu postgres "${POSTGRES_BIN_DIR}/pg_isready" -q -h /var/run/postgresql -p 5432; then
    bashio::log.error "PostgreSQL did not become ready in time; skipping post-start initialization."
    exit 1
fi

bashio::log.info "PostgreSQL started"

role_name="${ADDON_POSTGRES_USER}"
database_name="${ADDON_POSTGRES_DB}"
password_literal="$(sql_escape_literal "${ADDON_POSTGRES_PASSWORD}")"

gosu postgres "${POSTGRES_BIN_DIR}/psql" \
    --username postgres \
    --dbname postgres \
    --set ON_ERROR_STOP=1 <<SQL
DO \$\$
BEGIN
    IF NOT EXISTS (SELECT 1 FROM pg_catalog.pg_roles WHERE rolname = '${role_name}') THEN
        EXECUTE 'CREATE ROLE "${role_name}" LOGIN PASSWORD ''${password_literal}''';
    ELSE
        EXECUTE 'ALTER ROLE "${role_name}" WITH LOGIN PASSWORD ''${password_literal}''';
    END IF;
END
\$\$;

SELECT 'CREATE DATABASE "${database_name}" OWNER "${role_name}"'
WHERE NOT EXISTS (SELECT 1 FROM pg_database WHERE datname = '${database_name}')\gexec

GRANT ALL PRIVILEGES ON DATABASE "${database_name}" TO "${role_name}";
SQL

payload=$(\
    bashio::var.json \
        host "$(hostname)" \
        port "^5432" \
        username "${ADDON_POSTGRES_USER}" \
        password "${ADDON_POSTGRES_PASSWORD}" \
        database "${ADDON_POSTGRES_DB}"
)

bashio::services.delete "postgres" || true
bashio::log.info "Publishing PostgreSQL service information to Home Assistant"
bashio::services.publish "postgres" "${payload}"